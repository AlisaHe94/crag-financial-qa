GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here          # free fallback - get at https://aistudio.google.com/apikey
OPENAI_API_KEY=your_openai_api_key_here          # optional fallback
ANTHROPIC_API_KEY=your_anthropic_api_key_here    # optional fallback
TAVILY_API_KEY=your_tavily_api_key_here
SEC_EDGAR_USER_AGENT=you@example.com   # SEC requires a real contact email

# Model selection: "groq" | "openai" | "anthropic"
# Default = Llama-3.1-8B-Instant on Groq's LPU endpoint (~500 tok/s).
# Groq retired the 3B preview slot; 8B-instant is the smallest production
# Llama they currently host. See https://console.groq.com/docs/models for the
# current id list.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Optional fallback — if the primary returns a rate-limit / 5xx error, the
# call is silently retried on this provider. Recommended: gemini (free).
LLM_FALLBACK_PROVIDER=gemini

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
CROSS_ENCODER_MODEL=BAAI/bge-reranker-base

# Threading / segfault protection on Python 3.13 + Apple Silicon.
# These ALSO need to be exported in the shell before streamlit launches —
# see run.sh. Listed here for documentation + so non-streamlit entry points
# pick them up via python-dotenv.
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
JOBLIB_MULTIPROCESSING=0
PYTORCH_ENABLE_MPS_FALLBACK=1
EMBEDDING_DEVICE=cpu

# CRAG thresholds (tunable)
CRAG_THRESHOLD_HIGH=0.75
CRAG_THRESHOLD_LOW=0.40

# Data paths
DATA_DIR=data/sec_filings
VECTOR_DB_DIR=data/vectordb

# Evaluation
EVAL_QUESTIONS_PATH=data/eval_questions.json
